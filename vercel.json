{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/product", "destination": "/#product", "permanent": true },
    { "source": "/work", "destination": "/#work", "permanent": true },
    { "source": "/company", "destination": "/#company", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/investors/:path*",
      "destination": "/investors/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
